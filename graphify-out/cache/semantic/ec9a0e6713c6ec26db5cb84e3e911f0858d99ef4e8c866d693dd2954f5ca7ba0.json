{"nodes": [{"id": "wardove_mvvm_architecture", "label": "MVVM Architecture Pattern", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each screen has a paired ViewModel annotated with @HiltViewModel. Screens receive only callbacks and state; navigation happens in WardoveNavHost. This separation keeps UI logic testable and decoupled."}, {"id": "wardove_local_only_persistence", "label": "Local-Only Data Persistence Strategy", "file_type": "rationale", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "All persistence (Room DB, images in filesDir, DataStore) is local to the app sandbox and wiped on uninstall. There is no server/cloud backend. Moving to server-side persistence is a backend project, not a config flag."}, {"id": "wardove_wardrobe_database", "label": "WardoveDatabase (Room, version 2)", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "wardove_clothing_item_entity", "label": "ClothingItem Room Entity", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "wardove_wear_log_entity", "label": "WearLog Room Entity", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "wardove_laundry_cycle_entity", "label": "LaundryCycle Room Entity", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "wardove_laundry_cycle_item_entity", "label": "LaundryCycleItem Room Entity (Join Table)", "file_type": "concept", "source_file